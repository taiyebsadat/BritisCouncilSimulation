<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="oop_groupproject.britishcouncil.LoginController"
            prefHeight="400.0" prefWidth="600.0">
    <children>
        <Label layoutX="230.0" layoutY="60.0" text="British Council Login" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <TextField fx:id="userIdField" layoutX="210.0" layoutY="130.0" prefWidth="180.0" promptText="User ID (7 Digits)" />
        <PasswordField fx:id="passwordField" layoutX="210.0" layoutY="180.0" prefWidth="180.0" promptText="Password" />
        <Button layoutX="210.0" layoutY="230.0" prefWidth="180.0" text="Login" />
        <Label fx:id="errorLabel" layoutX="210.0" layoutY="280.0" textFill="RED" />
    </children>
</AnchorPane>