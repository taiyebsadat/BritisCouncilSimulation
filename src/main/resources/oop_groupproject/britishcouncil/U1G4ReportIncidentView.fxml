<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop_groupproject.britishcouncil.U1G4ReportIncidentController">
    <children>
        <TextField fx:id="studentIDTextField" layoutX="30.0" layoutY="50.0" promptText="Student ID" />
        <ComboBox fx:id="incidentTypeComboBox" layoutX="30.0" layoutY="90.0" promptText="Incident Type" />
        <TextArea fx:id="descriptionTextArea" layoutX="30.0" layoutY="130.0" prefHeight="100.0" prefWidth="400.0" promptText="Description" />
        <Button layoutX="30.0" layoutY="250.0" onAction="#submitReportButtonOnAction" text="Submit Report" />
      <Label layoutX="230.0" layoutY="14.0" text="Report Incident">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
