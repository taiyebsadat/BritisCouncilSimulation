<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop_groupproject.britishcouncil.U1G3RecordAttendanceController">
    <children>
        <TableView fx:id="recordAttendanceTableView" layoutX="30.0" layoutY="40.0" prefHeight="250.0" prefWidth="540.0">
            <columns>
                <TableColumn fx:id="idTableColumn" prefWidth="100" text="ID" />
                <TableColumn fx:id="nameTableColumn" prefWidth="200" text="Name" />
                <TableColumn fx:id="statusTableColumn" prefWidth="100" text="Status" />
                <TableColumn fx:id="seatNoTableColumn" prefWidth="100" text="Seat No" />
            </columns>
        </TableView>
        <Button layoutX="30.0" layoutY="310.0" onAction="#saveSeatingAndAttendanceButtongOnAction" text="Save Seating &amp; Attendance" />
    </children>
</AnchorPane>
